<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <modules>
        <!-- Remove WebDAV to prevent it from hijacking OPTIONS requests -->
        <remove name="WebDAVModule" />
      </modules>
      <handlers>
        <remove name="WebDAV" />
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet" arguments=".\EmployeeTracker.API.dll" stdoutLogEnabled="true" stdoutLogFile=".\logs\stdout" hostingModel="outofprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
          <environmentVariable name="CONNECTION_STRING" value="postgresql://neondb_owner:npg_2eKTfQcX4usL@ep-proud-smoke-anxm20bp.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require" />
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
